import { LayoutDashboard, List } from "lucide-react";
import {
  registerModule,
  registerNavItem,
  registerPermission,
  registerPermissionDefaults,
} from "~/registry";
import type { ModuleDefinition } from "~/registry";
import { {{MODULO_PASCAL}}_PERMISSIONS } from "./permissions";

export const {{MODULO_CAMEL}}Module: ModuleDefinition = {
