// ============================================================
// CORE — USUARIO
// ============================================================

model Usuario {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String
  nome           String   @default("")
  role           UserRole @default(viewer)
  userTipo       UserTipo @default(colaborador) @map("user_tipo")
  avatarUrl      String?  @map("avatar_url")
  ambiente       Ambiente @default(ambos)
  departamento   String?
  ativo          Boolean  @default(true)
  isSuperAdmin   Boolean  @default(false) @map("is_super_admin")
  empresaId      String?  @map("empresa_id") @db.Uuid
  celular        String?
  hubPoints      Int      @default(0) @map("hub_points")
  hubStatus      String?  @map("hub_status")
  hubAllowedTypes String? @map("hub_allowed_types")
  hubPreferences Json?    @map("hub_preferences")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  empresa              Empresa?              @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  permissoes           Permissoes?
  colaborador          Colaborador?
  parceiro             Parceiro?
  cliente              Cliente?

  @@map("profiles")
}

// ============================================================
// CORE — EMPRESA
// ============================================================

model Empresa {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome      String
  slug      String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  dados              EmpresaDados?
  endereco           EmpresaEndereco?
  documentos         EmpresaDocumento[]
  redesSociais       EmpresaRedesSocial?
  design             EmpresaDesign?
  departamentos      EmpresaDepartamento[]
  cargos             EmpresaCargo[]
  modulosEmpresa     ModuloEmpresa[]
  moduloLimits       EmpresaModuloLimit[]
  roleLimits         EmpresaRoleLimit[]
  usuarios           Usuario[]
  colaboradores      Colaborador[]
  parceiros          Parceiro[]
  clientes           Cliente[]
  cadastros          Cadastro[]
  credenciais        Credencial[]
  atividades         Atividade[]
  notificacoes       Notificacao[]
  notificacoesTemplates NotificacaoTemplate[]
  webhooks           Webhook[]
  webhookLogs        WebhookLog[]
  formSchema         FormSchema[]
  apiConnectors      ApiConnector[]
  integracoesConfig  IntegracaoConfig[]

  // Catálogo
  catalogoCategorias          CatalogoCategoria[]
  catalogoConexoes            CatalogoConexao[]
  catalogoFamilias            CatalogoFamilia[]
  catalogoLinhas              CatalogoLinha[]
  catalogoImplantes           CatalogoImplante[]
  catalogoImagensImplante     CatalogoImagemImplante[]
  catalogoFresas              CatalogoFresa[]
  catalogoProtocoloFresagem   CatalogoProtocoloFresagem[]
  catalogoTiposReabilitacao   CatalogoTipoReabilitacao[]
  catalogoTiposAbutment       CatalogoTipoAbutment[]
  catalogoAbutments           CatalogoAbutment[]
  catalogoCategoriasAcessorio CatalogoCategoriaAcessorio[]
  catalogoAcessorios          CatalogoAcessorio[]
  catalogoChavesFerramental   CatalogoChaveFerramental[]
  catalogoAcessorioFerramental CatalogoAcessorioFerramental[]
  catalogoCategoriasInstrumental CatalogoCategoriaInstrumental[]
  catalogoInstrumentaisGerais CatalogoInstrumentalGeral[]
  catalogoWorkflows           CatalogoWorkflow[]
  catalogoEtapasWorkflow      CatalogoEtapaWorkflow[]
  catalogoGuiasReabilitacao   CatalogoGuiaReabilitacao[]
  catalogoCategoriasKit       CatalogoCategoriaKit[]
  catalogoKits                CatalogoKit[]
  catalogoKitFamilias         CatalogoKitFamilia[]
  catalogoKitComposicao       CatalogoKitComposicao[]
  catalogoCupons              CatalogoCupom[]
  catalogoFretes              CatalogoFrete[]
  catalogoPromocionais        CatalogoPromocional[]

  @@map("empresas")
}

// ============================================================
// CORE — EMPRESA sub-entidades
// ============================================================

model EmpresaDados {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  empresaId String     @unique @map("empresa_id") @db.Uuid
  empTipo   TipoPessoa @map("emp_tipo")
  razao     String?
  fantasia  String?
  cnpj      String?
  cpf       String?
  email     String?
  celular   String?
  fixo      String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("empresa_dados")
}

model EmpresaEndereco {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  empresaId   String   @unique @map("empresa_id") @db.Uuid
  cep         String?
  logradouro  String?
  numero      String?
  bairro      String?
  complemento String?
  cidade      String?
  estado      String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("empresa_endereco")
}

model EmpresaDocumento {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  empresaId String   @map("empresa_id") @db.Uuid
  nome      String
  doc       String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("empresa_documentos")
}

model EmpresaRedesSocial {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  empresaId String   @unique @map("empresa_id") @db.Uuid
  instagram String?
  youtube   String?
  linkedin  String?
  facebook  String?
  tiktok    String?
  site      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("empresa_redes")
}

model EmpresaDesign {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  empresaId    String   @unique @map("empresa_id") @db.Uuid
  theme        Json     @default("{}")
  logoUrl      String?  @map("logo_url")
  logoIndexUrl String?  @map("logo_index_url")
  logoAppUrl   String?  @map("logo_app_url")
  faviconUrl   String?  @map("favicon_url")
  dbConfig     Json?    @map("db_config")
  updatedAt    DateTime @updatedAt @map("updated_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("empresa_design")
}

model EmpresaDepartamento {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  empresaId String   @map("empresa_id") @db.Uuid
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, nome])
  @@map("empresa_departamentos")
}

model EmpresaCargo {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  empresaId String   @map("empresa_id") @db.Uuid
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, nome])
  @@map("empresa_cargos")
}

// ============================================================
// CORE — PERMISSÕES
// ============================================================

model Permissoes {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId     String    @unique @map("usuario_id") @db.Uuid
  empresaId     String?   @map("empresa_id") @db.Uuid
  permissoes    Json      @default("{}")
  modulosAcesso Json      @default("{}") @map("modulos_acesso")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  updatedBy     String?   @map("updated_by") @db.Uuid

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("permissoes")
}

// ============================================================
// CORE — COLABORADOR
// ============================================================

model Colaborador {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId String   @unique @map("usuario_id") @db.Uuid
  empresaId String   @map("empresa_id") @db.Uuid
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  dados     ColabDados?
  endereco  ColabEndereco?
  documentos ColabDocumento[]
  redes     ColabRedes?

  @@map("colaboradores")
}

model ColabDados {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  colabId   String   @unique @map("colab_id") @db.Uuid
  nome      String
  email     String?
  celular   String?
  fixo      String?
  ramal     String?
  tipo      String?
  avatar    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  colaborador Colaborador @relation(fields: [colabId], references: [id], onDelete: Cascade)

  @@map("colab_dados")
}

model ColabEndereco {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  colabId     String   @unique @map("colab_id") @db.Uuid
  cep         String?
  logradouro  String?
  numero      String?
  bairro      String?
  complemento String?
  cidade      String?
  estado      String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  colaborador Colaborador @relation(fields: [colabId], references: [id], onDelete: Cascade)

  @@map("colab_endereco")
}

model ColabDocumento {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  colabId   String   @map("colab_id") @db.Uuid
  nome      String
  doc       String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  colaborador Colaborador @relation(fields: [colabId], references: [id], onDelete: Cascade)

  @@map("colab_documento")
