  familia CatalogoFamilia  @relation(fields: [familiaId], references: [id], onDelete: Cascade)

  @@id([empresaId, kitSku, familiaId])
  @@map("catalogo_kit_familias")
}

model CatalogoKitComposicao {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  kitSku          String   @map("kit_sku") @db.Uuid
  quantidade      Int      @default(1)
  fresaSku        String?  @map("fresa_sku") @db.Uuid
  chaveSku        String?  @map("chave_sku") @db.Uuid
  acessorioSku    String?  @map("acessorio_sku") @db.Uuid
  instrumentalSku String?  @map("instrumental_sku") @db.Uuid
  implanteSku     String?  @map("implante_sku") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  empresa      Empresa                   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  kit          CatalogoKit               @relation(fields: [kitSku, empresaId], references: [sku, empresaId], onDelete: Cascade)
  fresa        CatalogoFresa?            @relation(fields: [fresaSku, empresaId], references: [sku, empresaId], onDelete: Cascade)
  chave        CatalogoChaveFerramental? @relation(fields: [chaveSku, empresaId], references: [sku, empresaId], onDelete: Cascade)
  acessorio    CatalogoAcessorio?        @relation(fields: [acessorioSku, empresaId], references: [sku, empresaId], onDelete: Cascade)
  instrumental CatalogoInstrumentalGeral? @relation(fields: [instrumentalSku, empresaId], references: [sku, empresaId], onDelete: Cascade)
  implante     CatalogoImplante?         @relation(fields: [implanteSku, empresaId], references: [sku, empresaId], onDelete: Cascade)

  @@map("catalogo_kit_composicao")
}

