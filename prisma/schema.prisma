// ============================================================
// ERP Conexão — Prisma Schema (Refatoração Completa)
// ============================================================
// Base: ~92 tabelas SQL → Schema normalizado
// Multi-tenant: empresa_id em toda tabela de dados
// Auth: Supabase Auth (auth.users) — FK referenciada indiretamente
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

